{
  "name": "@khankudo/kisdb",
  "module": "kcp.ts",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "exports": {
    ".": "./kcp.ts",
    "./viewer/*": "./viewer/*.ts",
    "./client/*": "./client/*.ts",
    "./server/*": "./server/*.ts",
    "./db/*": "./db/*.ts"
  },
  "scripts": {
    "build": "cd dev; bun build client.ts --target browser --bundle --outfile browser.js",
    "dev": "bun run build && cd dev && bun run dev.ts"
  },
  "type": "module"
}